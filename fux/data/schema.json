{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fux rule entry",
  "description": "Validated frontmatter for a .fux/rules/*.md entry (plan §6).",
  "type": "object",
  "required": ["id", "type", "status"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "domain": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["rule", "formula", "glossary", "invariant", "adr", "edge-case",
               "convention", "regulatory", "runbook", "narrative", "memory",
               "spec", "task"]
    },
    "subtype": { "type": "string", "enum": ["user", "feedback", "project", "reference"] },
    "scope": { "type": "string", "enum": ["personal", "shared"] },
    "status": { "type": "string", "enum": ["draft", "active", "deprecated", "todo", "done"] },
    "tier": { "type": "string", "enum": ["constitutional", "standard", "advisory"], "default": "standard" },
    "principle": { "type": "string" },
    "enforcement": { "type": "string", "enum": ["deterministic", "judgment"] },
    "ratification": {
      "type": "object",
      "required": ["by", "date", "content_seal"],
      "properties": {
        "by": { "type": "string" },
        "date": { "type": "string" },
        "content_seal": { "type": "string" },
        "debate_hash": { "type": "string" },
        "supersedes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "created": { "type": "string" },
    "updated": { "type": "string" },
    "author": { "type": "string" },
    "source": { "type": "string" },
    "source_type": { "type": "string", "enum": ["url", "pdf", "xlsx", "txt", "image"] },
    "fetched": { "type": "string" },
    "source_hash": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "code_refs": { "type": "array", "items": { "type": "string" } },
    "related": { "type": "array", "items": { "type": "string" } },
    "edges": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "type": "string" } },
      "properties": {
        "depends-on": { "type": "array" },
        "supersedes": { "type": "array" },
        "contradicts": { "type": "array" },
        "implements": { "type": "array" }
      }
    },
    "seal": { "type": "string" },
    "check": { "type": "string" },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["given", "expect"],
        "properties": { "given": { "type": "string" }, "expect": { "type": "string" } }
      }
    }
  }
}
